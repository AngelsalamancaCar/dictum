{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "draft_output",
  "type": "object",
  "required": ["sections", "cited_ruling_ids"],
  "properties": {
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "text"],
        "properties": {
          "label": { "type": "string" },
          "text": { "type": "string" }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "cited_ruling_ids": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
